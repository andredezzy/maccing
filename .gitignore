.worktrees/

# Claude Code local artifacts — worktree storage (.claude/settings.json stays tracked) and the
# plugin-in-use marker the dev symlink writes into the repo when a plugin is installed from this path
.claude/worktrees/
**/.in_use/

# macOS
.DS_Store

# MCP secrets — `.env` files are committed templates; `.env.local` holds the real secrets (never commit)
**/.env.local

# Node — dev-only type deps for the MCP servers (@types/bun); the servers run with zero runtime deps
node_modules/

# Test coverage output (`bun test --coverage`)
**/coverage/

# Python
__pycache__/
*.pyc
