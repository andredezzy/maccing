# Template (committed). Copy to `.env.local` (gitignored) and fill in — start.sh loads `.env.local`.
# Alternatively `export NOTION_TOKEN=...` in your shell (.mcp.json forwards it).
#
# NOTION_TOKEN — Notion internal-integration Personal Access Token:
#   notion.so/profile/integrations -> Personal access tokens.
export NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OPTIONAL: private app API (UI-only features like database property/column icons) ---
# Unofficial, session-cookie auth, against Notion's ToS for programmatic use — see
# skills/notion-api/references/private-api.md. token_v2 ROTATES; store ONLY in .env.local.
#   NOTION_TOKEN_V2  — the BROAD-DOMAIN `.app.notion.com` token_v2 cookie (the exact-host
#                      `app.notion.com` cookie is a different value and is rejected).
#   NOTION_SPACE_ID  — your workspace/space id.
# export NOTION_TOKEN_V2=v03%3A...
# export NOTION_SPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
